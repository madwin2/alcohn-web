# ============================================================================
# Variables de entorno — Alcohn Web
# ----------------------------------------------------------------------------
# Copiar este archivo a `.env.local` para desarrollo local y completar valores.
# En Vercel: cargar las mismas claves en el panel del proyecto.
# `.env` y `.env*.local` están en .gitignore.
# ============================================================================

# Supabase (proyecto compartido con la app interna)
# Encontrar en Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (optimización / análisis de logo del wizard)
OPENAI_API_KEY=

# Openpay Argentina (BBVA / GeoPagos) — credenciales de OAuth
OPENPAY_CLIENT_ID=
OPENPAY_CLIENT_SECRET=
# (opcional) override de endpoint si se usa staging
# OPENPAY_CHECKOUT_API_BASE_URL=
# Pruebas: cobra solo este monto en Openpay (ej. 100). Quitar en producción.
# OPENPAY_TEST_AMOUNT_ARS=100

# Desarrollo: al pagar con tarjeta, salta Openpay y va directo a "Pago recibido".
# Solo funciona con npm run dev (no en producción). Quitar antes de deploy.
# OPENPAY_SIMULATE_SUCCESS=true

# URL pública del sitio (producción: https://tudominio.com)
# NEXT_PUBLIC_SITE_URL=https://alcohn.com.ar

# Google Tag Manager (GA4 y otros tags se configuran dentro del contenedor GTM)
NEXT_PUBLIC_GTM_ID=GTM-5NSG5G4L

# Meta Pixel (Facebook / Instagram Ads)
NEXT_PUBLIC_META_PIXEL_ID=

# Pruebas Openpay en local: la pasarela rompe http://localhost al volver del pago.
# Usá un túnel HTTPS (ngrok http 3000) y pegá acá la URL https del túnel:
# OPENPAY_REDIRECT_BASE_URL=https://xxxx.ngrok-free.app
